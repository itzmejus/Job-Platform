# Supabase (Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret required on the `Authorization: Bearer <secret>` header of
# /api/cron/* routes. Generate with: openssl rand -hex 32
CRON_SECRET=

# Job sources — every one of these is optional. An adapter whose key is
# missing is automatically disabled (logged, never crashes the sync run).
# Arbeitnow and Bundesagentur für Arbeit need no configuration at all — they
# work out of the box (Bundesagentur uses a public, openly documented static
# key by default; only set BUNDESAGENTUR_API_KEY if that ever changes).
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
JOOBLE_API_KEY=
BUNDESAGENTUR_API_KEY=

# Email digest (Resend). Optional — digest sending is skipped and logged if unset.
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_TO=
